# SNS Agent - 環境変数サンプル
# このファイルを .env にコピーして値を設定してください

# データベース接続URL
# ローカル開発: SQLite
DATABASE_URL=file:./dev.db
# 本番: PostgreSQL
# DATABASE_URL=postgres://user:password@localhost:5432/sns_agent

# 暗号化キー（OAuth トークン・API キーの暗号化に使用）
# 本番環境では必須。開発環境では省略可
# openssl rand -hex 32 で生成推奨
ENCRYPTION_KEY=

# API サーバーポート（デフォルト: 3001）
API_PORT=3001

# Web UI の URL（デフォルト: http://localhost:3000）
WEB_URL=http://localhost:3000

# 実行環境（development / production / test）
NODE_ENV=development

# OAuth プロバイダ設定（必要なものだけ設定）
# X (Twitter)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_PREMIUM=

# Instagram
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_WEBHOOK_SECRET=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# LINE
LINE_CHANNEL_SECRET=
LINE_TOKEN_TTL_SECONDS=
