    "@sns-agent/provider-line": "workspace:*",
    "@sns-agent/provider-x": "workspace:*",
    "@sns-agent/skills": "workspace:*",
    "hono": "^4.7.6",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
